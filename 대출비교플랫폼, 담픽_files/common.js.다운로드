$(document).on('click', '.eveSubmitBtn', function (e) {
    e.preventDefault();
    e.stopPropagation();

    var $form = $(this.form);

    if ($form.find('[name="name"]').val() == "") {
        alert("성함을 입력하세요");
        return false;
    }
    if ($form.find('[name="hp1"]').val() == "" || $form.find('[name="hp2"]').val() == "" || $form.find('[name="hp3"]').val() == "") {
        alert("연락처를 입력하세요");
        return false
    }
    var phone = $form.find('[name="hp1"]').val() + "-" + $form.find('[name="hp2"]').val() + "-" + $form.find('[name="hp3"]').val();
    $form.find('[name="phone"]').val(phone);

    if ($form.find('[name="policy"]').is(":checked") == false) {
        alert("개인정보처리방침을 동의해야 합니다.");
        return false
    }

    $.ajax({
        type: 'post',
        url: 'https://moum-on.co.kr/inst_in/inst_in_dampick_co_kr_oneWay.asp',
        data: $form.serialize(),
        dataType: 'html',
        success: function (e) {
            var chk = e;
            console.log(chk);
            if (chk == "상담신청완료") {
                location.href = '/done.php';
                return false;
            } else if (chk == "중복접수") {
                alert("중복접수");
                return false;
            } else {
                alert("접수실패");
                return false;
            }
        },
        error: function (response) {
            if (response.responseJSON.message) {
                alert(response.responseJSON.message);
            }
            if (response.responseJSON.inputName) {
                $form.find('[name="' + response.responseJSON.inputName + '"]').focus();
            }
        },
    });
});
function ajaxSend(ths) {
