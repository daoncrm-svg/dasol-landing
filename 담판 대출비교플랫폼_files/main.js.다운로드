$(function(){
	/// tab
	$('.msec-01').find('.tab').find('li > a').on('click',function(){
		var tabIndex2 = $(this).parent().index();
		$(this).parent('li').addClass('active');
		$(this).parent('li').siblings('li').removeClass('active');
		$('.invite-slide').trigger('to.owl.carousel',[tabIndex2,400]);
	});

	// icon-down
	$('.icon-down').addClass('on');
	$('.icon-down').click(function(){
		var headerH = $('#header').outerHeight();
		var secOffset = $($(this).attr("data-sec")).offset().top;
		$('body, html').stop().animate({
			scrollTop: secOffset - headerH,
		},400);
	});

	// invite-slide
	var inviteSlide = $('.invite-slide');
	inviteSlide.owlCarousel({
		items: 1,      
		autoHeight:false,
		loop: true,   
		margin: 30,   
		mouseDrag: true, 
		touchDrag: true,
		nav:false,       
		autoplay: false,  
		dots:true,      
		autoplayTimeout: 3500,  
		autoplayHoverPause: false, 
		autoWidth:false, 
		responsiveRefreshRate: 1,
     });
	$('.invite-ctrl > .next').click(function() {
		inviteSlide.trigger('next.owl.carousel');
	})
	$('.invite-ctrl > .prev').click(function() {
		inviteSlide.trigger('prev.owl.carousel', [600]);
	});
	$('.invite-slide').on('initialized.owl.carousel changed.owl.carousel', function(e) {
		var carousel = e.relatedTarget;
		$('.msec-01').find('.tab').find('li').removeClass('active');
		$('.msec-01').find('.tab').find('li:eq('+carousel.relative(carousel.current()) +')').addClass('active');
	});

	// event-slide
	var eventSlide = $('.event-slide');
	eventSlide.owlCarousel({
		items: 3,      
		autoHeight:false,
		loop: true,   
		margin: 30,   
		mouseDrag: true, 
		touchDrag: true,
		nav:false,       
		autoplay: false,  
		dots:true,      
		autoplayTimeout: 3500,  
		autoplayHoverPause: false, 
		autoWidth:false, 
		responsiveRefreshRate: 1,
		responsive:{ 
			0:{
				items:1,
				margin: 30,   
			},
			680:{
				items:2,
				margin: 20,   
			},
			1000:{
				items:3,
				margin: 30, 
				autoWidth:false, 
			},
		}
     });
	$('.event-ctrl > .next').click(function() {
		eventSlide.trigger('next.owl.carousel');
	})
	$('.event-ctrl > .prev').click(function() {
		eventSlide.trigger('prev.owl.carousel', [600]);
	});


	// top-btn & scroll
	if($(".top-btn").length<1) $("<a href='#n' class='top-btn'><span class='blind'>top</span></a>").appendTo($("#doc"));
	$('.top-btn').click(function(){
		$("body, html").animate({
				scrollTop: 0
		}, 500)
	});

$(window).scroll(function() {
	var position = $(window).scrollTop(); 
	if (position > 300){
		$('.top-btn').addClass('over');
	}else{
		$('.top-btn').removeClass('over');
	}
});
