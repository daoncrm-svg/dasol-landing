var myVar = null;
$(function(){
	setTimeout(function() {
	  $('#doc').addClass('show');
	}, 350);
	
	
	// allmenu script
	$('.bt-allmenu').bind("click",function(){
		if($(this).hasClass('active')){
			$(this).removeClass('active');
			$("body").css({"overflow":"visible"});  
			//$('#header-wrap').removeClass('isOver');
			 $('#allmenu-wrap').stop().fadeOut().removeClass('open')	
		}else{
			 $(this).addClass('active');
			 $("body").css({"overflow":"hidden"});  
			 //$('#header-wrap').addClass('isOver');
			  $('#allmenu-wrap').stop().fadeIn().addClass('open')	
		}
		$('#doc').css({'z-index':'9999'});
	});
	$('#allmenu-wrap').find('.close').bind("click",function(){
		$('.bt-allmenu').removeClass('active');
		$("body").css({"overflow":"visible"});   
	    $('#allmenu-wrap').stop().fadeOut('slow').removeClass('open')	
		
		$('#doc').css({'z-index':'8999'});
	});


	$('#allmenu-wrap').find('.mn_a1').on('hover mouseenter',function(){
		 var isIndex = $(this).parent().index() + 1
		 $(this).parent().removeClass('read').addClass('hover')
		 $(this).parent().siblings('li').addClass('read').removeClass('hover');

		 $('#allmenu-wrap').find('.close').addClass('over');
		 $('#allmenu-wrap').find('.bg').removeClass('bg1 bg2 bg3 bg4 bg5 bg6 bg7').addClass('bg'+isIndex).stop().fadeIn();
	});
	$('.allmenu').mouseleave(function(){
		$('.allmenu').find('.mn_l1').removeClass('hover read');
		$('#allmenu-wrap').find('.close').removeClass('over');
		$('#allmenu-wrap').find('.bg').stop().fadeOut();
		setTimeout(function() {
		  $('#allmenu-wrap').removeClass('bg1 bg2 bg3 bg4 bg5 bg6 bg7')
		}, 250);
	});

	

	if($(".layer-language").find('.over-bg').length<1) $("<div class='over-bg'/>").appendTo($(".layer-language"));
	$('.bt-language').on('hover mouseover', function(){
		var docW = $("#doc").innerWidth();
		if(docW > 1184){
			if($(this).hasClass('active')){
				$(this).removeClass('active');	
				$(".layer-language").stop().fadeOut('fast');
			}else{
				$(this).addClass('active');
				$(".layer-language").stop().fadeIn('fast');
			}
		}
		
	});
	$('.bt-language').on('click', function(){
		var docW = $("#doc").innerWidth();
		if(docW < 1185){
			if($(this).hasClass('active')){
				$(this).removeClass('active');	
				$(".layer-language").stop().fadeOut('fast');
			}else{
				$(this).addClass('active');
				$(".layer-language").stop().fadeIn('fast');
			}
		}
	});
	$('.layer-language').find('li > a').click(function(){
		var istxt = $(this).find('span').text();
		$('.bt-language').find('span').text(istxt);
		$('.bt-language').removeClass('active');
		$(this).parent().addClass('active');
        $(this).parent().siblings('li').removeClass('active');

		$(".layer-language").stop().fadeOut('fast');
		$('.bt-language').removeClass('active');
	});
	$('.layer-language').bind('mouseleave',function(){
		var docW = $("#doc").innerWidth();
		if(docW > 1184){
			$(".layer-language").stop().fadeOut('fast');
			$('.bt-language').removeClass('active');
		}
	});
	var $eback = $(".layer-language").find(".over-bg");
	$eback.unbind("click").bind("click",function(){
		$('.bt-language').removeClass('active');
		$(".layer-language").stop().fadeOut('fast');
	}).show();

});	
$(window).scroll(function() {
	var position = $(window).scrollTop(); 
	var bodyWidth = document.documentElement.clientWidth; 
	if (position > 0){
		$('#header-wrap').addClass('fix');
	}else{
		$('#header-wrap').removeClass('fix');
	}
	
});
$(window).load(function(){
	var position = $(window).scrollTop(); 
	var bodyWidth = document.documentElement.clientWidth; 
	if (position > 0){
		$('#header-wrap').addClass('fix');
	}else{
		$('#header-wrap').removeClass('fix');
	}
});


function sizeControls(width) {
	width = parseInt(width);
	var bodyHeight = document.documentElement.clientHeight; 
	var bodyWidth = document.documentElement.clientWidth; 
	var docW = $('#doc').innerWidth();
	var navH01 = $('#mainNavi').outerHeight();
	var navH02 = $('.nav').outerHeight();
	var navHtotal = navH01 + navH02;
	//console.log(bodyWidth);
	
}
jQuery(function($){
	sizeControls($(this).width());
	$(window).resize(function() {
		if(this.resizeTO) {
			clearTimeout(this.resizeTO);
		}
		this.resizeTO = setTimeout(function() {
			$(this).trigger('resizeEnd');
		}, 10);
	});
});	
$(window).on('resizeEnd', function() {
	sizeControls($(this).width());
});
$(window).load( function() { 
	sizeControls($(this).width());
});


function clearText(thefield) {
  if (thefield.defaultValue==thefield.value) {
    thefield.value="";
  }
} 
function defaultText(thefield) {
  if (thefield.value=="") {
    thefield.value=thefield.defaultValue;
  }
}
