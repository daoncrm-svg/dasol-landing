function notEucKR_Check(str)
{
	var chr;
    var notstr = new Array();
    var j = 0;

	for (var i=0; i<str.length; i++)
    {
		if (str.charCodeAt(i) > 127)
        {
			chr = str.charAt(i);
			if (MSG_CHAR_CHECK.indexOf(chr) < 0)
            {
				notstr[j] = chr;
                j++;
			}
		}
	}

	var rslt = (j > 0) ? notstr.join(", ") : null;

    return rslt;
}
