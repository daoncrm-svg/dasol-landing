function getChkCnt(form_name, element_name)
{
	var chklen = 0;
	var form_element;

	form_element = eval("document."+form_name+"."+element_name);
	var cnt = getChkLen(form_element);

	if(cnt==1){
		if(form_element.checked==true)
			chklen = 1;
		else
			chklen = 0;
	}
	else{
		for(i=0; i<cnt; i++){
			form_element = eval("document."+form_name+"."+element_name+"["+i+"]");
			if(form_element.checked==true)
				chklen += 1;
		}
	}

	return chklen;
}

